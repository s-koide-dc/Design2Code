    "role_synonyms": {
        "content": ["data", "result", "READ", "FETCH", "TRANSFORM"],
        "data": ["content", "result", "item", "READ", "FETCH", "TRANSFORM"],
        "path": ["url", "source"]
    },
    "role_scoring": {
        "exact_match": 10,
        "synonym_match": 5,
        "fallback": 1,
        "transform_penalty": -2
    },
    "transform_ops": {
        "trim_upper": {
            "input_role": "content",
            "output_type": "string",
            "output_name": "text",
            "code": "{out} = {src}.Trim().ToUpperInvariant();"
        },
        "split_lines": {
            "input_role": "content",
            "output_type": "List<string>",
            "output_name": "lines",
            "usings": ["System", "System.Linq"],
            "code": "{out} = {src}.Split(new[] {{ \"\\r\\n\", \"\\n\" }}, StringSplitOptions.RemoveEmptyEntries).ToList();"
        },
        "format_kv": {
            "input_role": "content",
            "output_type": "string",
            "output_name": "formatted",
            "code": "{out} = $\"MODE={{{{v0}}}}, REGION={{{{v1}}}}\";"
        },
        "csv_serialize": {
            "input_role": "content",
            "output_type": "string",
            "output_name": "csv",
            "usings": ["System", "System.Linq"],
            "code": "{out} = string.Join(Environment.NewLine, {src}.Select(kv => $\"{{kv.Key}},{{kv.Value}}\"));"
        }
    },
