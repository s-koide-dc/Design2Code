    "design_doc_refiner": {
        "input_header_pattern": "(###?\\s*Input\\s*)",
        "output_header_pattern": "(###?\\s*Output\\s*)",
        "description_label": "Description",
        "input_description_template": "{params} を入力として受け取ります。",
        "output_description_template": "`{return_type}` 型の値を返します。",
        "logic_placeholder_pattern": "\\(ロジックの詳細をここに記述してください。.*?\\)",
        "logic_placeholder_max_methods": 5,
        "logic_placeholder_line_template": "{index}. `{method}` メソッドを呼び出し、必要な処理を実行します。",
