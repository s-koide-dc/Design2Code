  "exclusion_rules": {
    "file_patterns": [
      "*.Designer.cs",
      "*.g.cs",
      "*.generated.cs",
      "**/bin/**",
      "**/obj/**",
      "**/node_modules/**",
      "**/__pycache__/**",
      "**/dist/**",
      "**/build/**"
    ],
    "directory_patterns": [
      "bin",
      "obj",
      "node_modules",
      "__pycache__",
      ".git",
      "dist",
      "build",
      "packages"
    ],
    "content_patterns": [
      "// <auto-generated",
      "# Generated by",
      "/* eslint-disable */",
      "// This file is automatically generated"
    ]
  },
        "csharp": {
          "smell_thresholds": {
            "long_method_lines": 20,
            "cyclomatic_complexity": 10,
            "parameter_count": 5,
            "class_line_count": 300,
            "god_class_method_count": 15
          },
          "auto_fix_enabled": ["rename_variable", "extract_constant"],
          "safety_checks": ["test_coverage", "dependency_analysis"]
        },  "python": {
    "smell_thresholds": {
      "long_method_lines": 25,
      "cyclomatic_complexity": 8,
      "parameter_count": 4
    },
    "tools": ["pylint", "flake8"]
  },
  "javascript": {
    "smell_thresholds": {
      "long_function_lines": 15,
      "cyclomatic_complexity": 6,
      "parameter_count": 3
